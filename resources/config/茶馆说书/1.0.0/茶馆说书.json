{
  "name": "茶馆说书",
  "version": "1.0.0",
  "author": "Thrient",
  "description": "茶馆说书任务并进行随机答题",
  "start": "",
  "steps": {
    "茶馆说书前往": {
      "action": "touch",
      "params": {
        "args": [
          "按钮活动茶馆说书"
        ],
        "y": 45
      },
      "success": "等待到达NPC",
      "prefix": [
        {
          "step": "打开江湖"
        }
      ]
    },
    "等待到达NPC": {
      "action": "touch",
      "params": {
        "args": [
          "按钮进入茶馆"
        ]
      },
      "prefix": [
        {
          "step": "等待到达"
        }
      ],
      "success": "等待退出茶馆"
    },
    "随机答题": {
      "action": "touch",
      "params": {
        "args": [
          "按钮茶馆甲",
          "按钮茶馆乙",
          "按钮茶馆丙",
          "按钮茶馆丁"
        ]
      }
    },
    "检查茶馆": {
      "action": "exits",
      "params": {
        "args": [
          "界面茶馆"
        ]
      },
      "postfix": [],
      "success": "随机答题"
    },
    "等待退出茶馆": {
      "action": "touch",
      "params": {
        "args": [
          "按钮退出茶馆"
        ],
        "seconds": 300
      },
      "retry": {
        "times": 3,
        "interval": 0
      },
      "postfix": [
        {
          "step": "关闭奖励弹窗*12"
        }
      ]
    }
  },
  "common": {},
  "monitors": {
    "loop": [
      "检查茶馆"
    ],
    "interval": 1
  },
  "values": {},
  "layout": []
}