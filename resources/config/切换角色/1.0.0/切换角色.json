        {
          "step": "切换角色2",
          "when": "{切换角色 == '角色2'}"
        },
        {
          "step": "切换角色3",
          "when": "{切换角色 == '角色3'}"
        },
        {
          "step": "切换角色4",
          "when": "{切换角色 == '角色4'}"
        },
        {
          "step": "切换角色5",
          "when": "{切换角色 == '角色5'}"
        },
