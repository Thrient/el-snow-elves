{
  "name": "世界喊话",
  "version": "1.0.0",
  "author": "Thrient",
  "description": "世界喊话",
  "start": "乘坐坐骑",
  "steps": {
    "乘坐坐骑": {
      "action": "touch",
      "params": {
        "args": [
          "按钮大世界坐骑"
        ]
      },
      "prefix": [
        {
          "step": "检测主界面"
        }
      ],
      "next": "世界喊话"
    },
    "世界喊话": {
      "action": "{True}",
      "params": {},
      "prefix": [
        {
          "step": "重置索引",
          "args": {},
          "when": "{index >= len(喊话内容)}"
        },
        {
          "step": "普通世界喊话",
          "args": {
            "文本": "{喊话内容[index]}"
          }
        }
      ],
      "postfix": [
        {
          "step": "退出世界"
        },
        {
          "step": "递增索引",
          "args": {}
        }
      ],
      "next": "判断结束"
    },
    "重置索引": {
      "action": "{True}",
      "set": [
        {
          "name": "index",
          "value": 0
        }
      ]
    },
    "递增索引": {
      "action": "{True}",
      "set": [
        {
          "name": "index",
          "value": "{index}++"
        }
      ]
    },
    "判断结束": {
      "action": "{喊话次数索引 >= 喊话次数}",
      "params": {},
      "failure": "乘坐坐骑",
      "set": [
        {
          "name": "喊话次数索引",
          "value": "{喊话次数索引}++"
        }
      ],
      "postfix": [
        {
          "step": "等待时间",
          "args": {
            "等待时间": "30"
          }
        }
      ]
    }
  },
  "common": {},
  "monitors": {
    "loop": [],
    "interval": 1
  },
  "values": {
    "喊话内容": "",
    "喊话次数": 100,
    "index": 0,
    "喊话次数索引": 0
  },
  "layout": [
    [
      {
        "span": 24,
        "model": "el-input-tags",
        "store": "喊话内容"
      }
    ],
    [
      {
        "span": 12,
        "model": "el-input-number",
        "store": "喊话次数"
      }
    ]
  ]
}