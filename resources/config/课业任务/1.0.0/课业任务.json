{
  "name": "课业任务",
  "description": "日常课业玩法",
  "version": "1.0.0",
  "author": "Thrient",
  "start": "查找课业任务",
  "values": {

  },
  "layout": [

  ],
  "monitors": {
    "loop": [
      "一键提交"
    ],
    "interval": 1
  },
  "common": {
    "课业确定": {
      "action": "touch",
      "params": {
        "args": [
          "按钮确定"
        ]
      },
      "postfix": [
        "关闭奖励弹窗*12"
      ],
      "next": "任务结束"
    },
    "一键提交": {
      "action": "touch",
      "params": {
        "args": [
          "按钮一键提交"
        ],
        "seconds": null
      },
      "next": "任务结束"
    },
    "课业对话确定": {
      "action": "touch",
      "params": {
        "args": [
          "按钮课业确定"
        ]
      },
      "next": "任务结束"
    },
    "前往课业NPC": {
      "action": "touch",
      "params": {
        "args": [
          "按钮课业前往"
        ],
        "box": [
          178,
          443,
          399,
          582
        ]
      },
      "postfix": [
        "等待到达"
      ],
      "next": "任务结束"
    },
    "对话课业NPC": {
      "action": "touch",
      "params": {
        "args": [
          "按钮课业",
          "按钮悟禅"
        ],
        "click_mode": "last"
      },
      "prefix": [
        "前往课业NPC"
      ],
      "postfix": [
        "课业对话确定"
      ],
      "next": "任务结束"
    }
  },
  "steps": {
    "查找课业任务": {
      "action": "touch",
      "params": {
        "args": [
          "按钮活动止杀",
          "按钮活动锻心",
          "按钮活动问卜",
          "按钮活动漱尘",
          "按钮活动归义",
          "按钮活动濯剑",
          "按钮活动吟风",
          "按钮活动悟禅",
          "按钮活动含灵",
          "按钮活动寻道",
          "按钮活动观梦",
          "按钮活动起茶"
        ],
        "y": 45
      },
      "prefix": [
        "打开江湖"
      ],
      "success": "接取课业任务",
      "failure": "任务结束"
    },
    "接取课业任务": {
      "action": "touch",
      "params": {
        "args": [
          "按钮课业困难",
          "按钮课业简单",
          "按钮课业普通"
        ]
      },
      "prefix": [
        "对话课业NPC"
      ],
      "next": "等待任务完成"
    },
    "等待任务完成": {
      "action": "touch",
      "params": {
        "args": [
          "标志课业完成"
        ],
        "threshold": 0.8,
        "seconds": 360
      },
      "success": "课业确定",
      "failure": "激活课业任务"
    },
    "激活课业任务": {
      "action": "touch",
      "params": {
        "args": [
          "按钮任务止杀",
          "按钮任务锻心",
          "按钮任务问卜",
          "按钮任务漱尘",
          "按钮任务归义",
          "按钮任务濯剑",
          "按钮任务吟风",
          "按钮任务悟禅",
          "按钮任务含灵",
          "按钮任务寻道",
          "按钮任务观梦",
          "按钮任务起茶"
        ]
      },
      "prefix": [
        "检测主界面",
        "激活状态栏"
      ],
      "next": "等待任务完成"
    }
  }
}